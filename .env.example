# --- Course / SQLite track (default) ---
# Scoring: default is Python (`jobs/run_inference.py` → order_predictions). Use mock if Python is missing:
# SCORING_PROVIDER=mock
#
# If `python` is not on PATH (common on macOS), use Python 3 explicitly:
# PYTHON_BIN=python3

# --- Optional: Postgres / Supabase ---
# When set, the app uses `pg` instead of shop.db (alternate schema in lib/sql/postgres.ts).
# Leave unset for the official chapter assignment (SQLite only).
# DATABASE_URL=postgresql://postgres.[ref]:[password]@....pooler.supabase.com:6543/postgres

# --- Optional: Supabase JS (not used by the pg data layer) ---
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
