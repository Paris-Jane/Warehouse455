# --- Course / SQLite track (default) ---
# Scoring: default is Python (`jobs/run_inference.py` → order_predictions). Use mock if Python is missing:
# SCORING_PROVIDER=mock
#
# If `python` is not on PATH (common on macOS), use Python 3 explicitly:
# PYTHON_BIN=python3

# --- Optional: Postgres / Supabase ---
# When set, the app uses `pg` instead of shop.db (alternate schema in lib/sql/postgres.ts).
# Leave unset for the official chapter assignment (SQLite only).
# DATABASE_URL=postgresql://postgres.[ref]:[password]@....pooler.supabase.com:6543/postgres
# Pooler hostnames use pooler.supabase.com (not *.supabase.co). The app relaxes TLS verify for both.
# Other hosts (e.g. Neon) on Vercel: set DATABASE_SSL_REJECT_UNAUTHORIZED=false if you see SELF_SIGNED_CERT_IN_CHAIN.
#
# Scoring on Postgres: create table order_predictions (see sql/postgres_order_predictions.sql) so mock scoring can upsert.

# --- Cron (daily scoring via /api/cron/scoring or scripts/cron-scoring.sh) ---
# Set the same value in Vercel project env; Vercel Cron sends Authorization: Bearer <CRON_SECRET>.
# CRON_SECRET=generate-a-long-random-string
# For curl-based crontab to your deployed app:
# CRON_SCORING_URL=https://your-deployment.vercel.app/api/cron/scoring

# --- Optional: Supabase JS (not used by the pg data layer) ---
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
